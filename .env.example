# SteelPlant Maintenance Wizard — Environment Variables
# Copy: cp .env.example .env

# ═══════════════════════════════════════════════════════════════
# LLM PROVIDERS — use at least ONE (Groq recommended for hackathon)
# Auto-fallback order when LLM_PROVIDER=auto:
# ═══════════════════════════════════════════════════════════════
LLM_PROVIDER=auto
LLM_FALLBACK_ORDER=groq,gemini,anthropic,openai,xai,ollama

# --- Groq (RECOMMENDED — generous free tier, very fast) ---
# https://console.groq.com/keys  → starts with gsk_
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini ---
# https://aistudio.google.com/apikey  → AIza… or newer AQ.… format
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic Claude ---
# https://console.anthropic.com/  → starts with sk-ant-
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- OpenAI ---
# https://platform.openai.com/api-keys  → starts with sk-
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- xAI Grok ---
# https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-2-latest

# 9-agent LangGraph (many API calls) — keep false on free tiers
ENABLE_FULL_AGENTIC=true

# ═══════════════════════════════════════════════════════════════
# DATABASE & SECURITY
# ═══════════════════════════════════════════════════════════════
SECRET_KEY=change-this-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional local LLM (install Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
